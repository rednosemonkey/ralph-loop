{
  "name": "ralph-loop",
  "version": "0.1.0",
  "description": "Autonomous coding loop powered by Claude. Iterates through user stories, codes, verifies, and retries until done.",
  "type": "module",
  "bin": {
    "ralph": "./bin/ralph.js"
  },
  "main": "./dist/ralph.js",
  "exports": {
    ".": "./dist/ralph.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "keywords": [
    "claude",
    "ai",
    "coding",
    "autonomous",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "commander": "^13.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0"
  }
}
